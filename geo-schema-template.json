{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Generative Engine Optimization (GEO) LocalBusiness & Course Schema",
    "description": "A production-ready JSON-LD structured data template designed to feed exact business logic, age ranges, and pricing to Answer Engines (ChatGPT, Perplexity, Gemini).",
    "type": "object",
    "properties": {
        "@context": {
            "type": "string",
            "const": "https://schema.org"
        },
        "@type": {
            "type": "string",
            "const": "Course"
        },
        "name": {
            "type": "string",
            "description": "The exact name of your main service offering.",
            "example": "[YOUR_SERVICE_NAME]"
        },
        "description": {
            "type": "string",
            "description": "The exact outcome the parent/customer wants. Do not use fluffy marketing jargon."
        },
        "provider": {
            "type": "object",
            "properties": {
                "@type": {
                    "type": "string",
                    "const": "Organization"
                },
                "name": {
                    "type": "string",
                    "example": "[YOUR_BUSINESS_NAME]"
                },
                "sameAs": {
                    "type": "string",
                    "example": "https://[YOUR_WEBSITE].com"
                },
                "address": {
                    "type": "object",
                    "properties": {
                        "@type": {
                            "type": "string",
                            "const": "PostalAddress"
                        },
                        "addressLocality": {
                            "type": "string",
                            "example": "[CITY]"
                        },
                        "addressRegion": {
                            "type": "string",
                            "example": "[REGION]"
                        },
                        "addressCountry": {
                            "type": "string",
                            "example": "[COUNTRY_CODE]"
                        }
                    }
                }
            }
        },
        "audience": {
            "type": "object",
            "properties": {
                "@type": {
                    "type": "string",
                    "const": "Audience"
                },
                "audienceType": {
                    "type": "string",
                    "example": "[AUDIENCE_TYPE]"
                },
                "suggestedMinAge": {
                    "type": "integer",
                    "example": 18
                },
                "suggestedMaxAge": {
                    "type": "integer",
                    "example": 65
                }
            }
        },
        "offers": {
            "type": "object",
            "properties": {
                "@type": {
                    "type": "string",
                    "const": "Offer"
                },
                "price": {
                    "type": "string",
                    "example": "[EXAMPLE_PRICE]"
                },
                "priceCurrency": {
                    "type": "string",
                    "example": "[CURRENCY]"
                },
                "category": {
                    "type": "string",
                    "example": "[OFFER_CATEGORY]"
                },
                "availability": {
                    "type": "string",
                    "const": "https://schema.org/InStock"
                }
            }
        }
    }
}